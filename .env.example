# ==========================================
# Timer.mn — Environment Variables
# Copy this file to .env.local and fill in all values
# ==========================================

# ---------------------------------------------------
# REQUIRED: Supabase (Database + Auth + Storage)
# ---------------------------------------------------
# Get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — ONLY for server-side / Edge Functions
# Never expose this to the client!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------
# REQUIRED: Mapbox (Maps)
# ---------------------------------------------------
# Get from https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your.mapbox.token

# ---------------------------------------------------
# REQUIRED: NextAuth (Session encryption)
# ---------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-long

# ---------------------------------------------------
# REQUIRED: App URL
# ---------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------
# OPTIONAL: QPay (Mongolian Payment)
# ---------------------------------------------------
# Get from QPay merchant dashboard
QPAY_USERNAME=your-qpay-username
QPAY_PASSWORD=your-qpay-password
QPAY_INVOICE_CODE=your-qpay-invoice-code

# ---------------------------------------------------
# OPTIONAL: SocialPay (Mongolian Payment)
# ---------------------------------------------------
SOCIALPAY_MERCHANT_ID=your-socialpay-merchant-id
SOCIALPAY_SECRET=your-socialpay-secret

# ---------------------------------------------------
# REQUIRED: SMS (Unitel)
# ---------------------------------------------------
# If not provided, SMS will be logged to console only
SMS_API_KEY=your-sms-api-key
SMS_API_SECRET=your-sms-api-secret
SMS_SENDER_ID=TimerMN
SMS_API_URL=https://api.unitel.mn/sms

# ---------------------------------------------------
# OPTIONAL: Vercel (for CLI deployments)
# ---------------------------------------------------
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id

# ---------------------------------------------------
# OPTIONAL: Monitoring / Analytics
# ---------------------------------------------------
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
